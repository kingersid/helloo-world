{
  "version": 2,
  "builds": [
    {
      "src": "mcp-server.js",
      "use": "@vercel/node",
      "config": {
        "installCommand": "npm install",
        "devCommand": "node mcp-server.js",
        "includeFiles": ["mcp-server.js", "mcp-server-package.json"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/mcp-server.js"
    }
  ]
}
